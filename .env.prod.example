# Domain (ohne https://)
DOMAIN=yourdomain.com

# App
APP_NAME="AUA Spielothek"
APP_KEY=                        # php artisan key:generate --show

# Datenbank (PostgreSQL)
DB_DATABASE=game_database
DB_USERNAME=game_user
